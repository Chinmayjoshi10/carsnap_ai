GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
# ANTHROPIC_API_KEY=          # uncomment for direct Anthropic API (client)
# AWS_ACCESS_KEY_ID=           # uncomment for AWS Bedrock
# AWS_SECRET_ACCESS_KEY=       # uncomment for AWS Bedrock
# AWS_REGION=us-east-1         # uncomment for AWS Bedrock
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
RESEND_API_KEY=your_resend_api_key_here
SENDER_EMAIL=your_sender_email_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
